<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F6F8"
    tools:context=".ApplicationsActivity">

    <!-- ═══════════════════════════════════════════════════
         STICKY HEADER — AppBarLayout (~124dp)
         ═══════════════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="4dp"
        app:liftOnScroll="false">

        <!-- ─── ROW 1: Top Bar (72dp) ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- Left group: icon button + title/subtitle text -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Back icon button -->
                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_primary_10"
                    android:contentDescription="@string/cd_back">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/cd_back"
                        android:src="@drawable/ic_arrow_back"
                        app:tint="#1A1A7F" />
                </FrameLayout>

                <!-- Title + Subtitle -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvHeaderTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:letterSpacing="-0.03"
                        android:lineHeight="22sp"
                        android:text="@string/header_title"
                        android:textColor="#0F172A"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvHeaderSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:lineHeight="16sp"
                        android:text="@string/header_subtitle"
                        android:textColor="#64748B"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Right group: Search + Menu icon buttons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Search / Filter button -->
                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_secondary"
                    android:contentDescription="@string/cd_search">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/cd_search"
                        android:src="@drawable/ic_search"
                        app:tint="#475569" />
                </FrameLayout>

                <!-- Menu / List button -->
                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_icon_secondary"
                    android:contentDescription="@string/cd_menu">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="12dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/cd_menu"
                        android:src="@drawable/ic_menu"
                        app:tint="#475569" />
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Horizontal divider between rows -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2E8F0" />

        <!-- ─── ROW 2: Tab Navigation (52dp) ─── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/tab_active_underline"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- Tab 1 — Inactive -->

            <!-- Tab 2 — Inactive -->

            <!-- Tab 3 — Active (with bottom underline + badge) -->
            <LinearLayout
                android:id="@+id/tabRejected"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@drawable/tab_active_underline"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="16dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:text="@string/tab_rejected"
                    android:textColor="#1A1A7F"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Count pill badge -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:background="@drawable/bg_pill_primary_10"
                    android:fontFamily="sans-serif"
                    android:paddingStart="6dp"
                    android:paddingTop="2dp"
                    android:paddingEnd="6dp"
                    android:paddingBottom="2dp"
                    android:text="@string/tab_rejected_count"
                    android:textColor="#1A1A7F"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ═══════════════════════════════════════════════════
         SCROLLABLE BODY — NestedScrollView
         ═══════════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section Header Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="0.05"
                    android:text="@string/section_label"
                    android:textAllCaps="true"
                    android:textColor="#64748B"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/section_meta"
                    android:textColor="#94A3B8"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- ═══════════════════════════════════════════
                 DYNAMIC RECYCLER VIEW FOR APPLICATIONS
                 ═══════════════════════════════════════════ -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvApplications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_application" />

            <!-- ═══════════════════════════════════════════
                 CARD 4 — alpha 0.9
                 ═══════════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:alpha="0.9"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="330dp"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_circle_primary_10"
                            android:contentDescription="@string/cd_application_icon">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/cd_application_icon"
                                android:src="@drawable/ic_document"
                                app:tint="#1A1A7F" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:fontFamily="sans-serif"
                                    android:lineHeight="24sp"
                                    android:text="@string/card4_title"
                                    android:textColor="#0F172A"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:background="@drawable/bg_badge_error"
                                    android:fontFamily="sans-serif"
                                    android:letterSpacing="-0.03"
                                    android:paddingStart="8dp"
                                    android:paddingTop="2dp"
                                    android:paddingEnd="8dp"
                                    android:paddingBottom="2dp"
                                    android:text="@string/badge_urgent"
                                    android:textAllCaps="true"
                                    android:textColor="#B91C1C"
                                    android:textSize="10sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">

                                    <ImageView
                                        android:layout_width="12dp"
                                        android:layout_height="15dp"
                                        android:contentDescription="@string/cd_location"
                                        android:src="@drawable/ic_location"
                                        app:tint="#475569" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="6dp"
                                        android:text="@string/card4_location"
                                        android:textColor="#475569"
                                        android:textSize="14sp" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="16dp"
                                    android:gravity="center_vertical"
                                    android:orientation="horizontal">

                                    <ImageView
                                        android:layout_width="13dp"
                                        android:layout_height="15dp"
                                        android:contentDescription="@string/cd_date"
                                        android:src="@drawable/ic_calendar"
                                        app:tint="#475569" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="6dp"
                                        android:text="@string/card4_date"
                                        android:textColor="#475569"
                                        android:textSize="14sp" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_error_box"
                        android:orientation="vertical"
                        android:paddingStart="12dp"
                        android:paddingTop="20dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="12dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif"
                            android:lineHeight="20sp"
                            android:text="@string/card4_reason"
                            android:textColor="#991B1B"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_button_primary"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="13dp"
                            android:layout_height="12dp"
                            android:contentDescription="@string/cd_resubmit"
                            android:src="@drawable/ic_upload"
                            app:tint="#FFFFFF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:fontFamily="sans-serif"
                            android:gravity="center"
                            android:text="@string/btn_resubmit"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
